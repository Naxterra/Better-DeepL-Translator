<Window x:Class="DeepLTranslator.TokenDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Verbindung einrichten"
        Width="520" Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgWindow}"
        Foreground="{StaticResource FgMain}"
        FontFamily="Segoe UI" FontSize="13">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="dl_access Token manuell eingeben"
                   FontSize="16" FontWeight="SemiBold"/>

        <Border Grid.Row="2" Background="{StaticResource BgPanel}"
                CornerRadius="6" Padding="14,10">
            <StackPanel>
                <TextBlock Foreground="{StaticResource FgMuted}" TextWrapping="Wrap">
                    <Run Text="1. "/>
                    <Run Text="Brave öffnen → deepl.com (ggf. einloggen)"/>
                </TextBlock>
                <TextBlock Foreground="{StaticResource FgMuted}" Margin="0,4,0,0" TextWrapping="Wrap">
                    <Run Text="2. "/>
                    <Run Text="F12 → Application → Cookies → https://www.deepl.com"/>
                </TextBlock>
                <TextBlock Foreground="{StaticResource FgMuted}" Margin="0,4,0,0" TextWrapping="Wrap">
                    <Run Text="3. "/>
                    <Run Text="Zeile dl_access anklicken (Wert beginnt mit eyJ…)"/>
                </TextBlock>
                <TextBlock Foreground="{StaticResource FgMuted}" Margin="0,4,0,0" TextWrapping="Wrap">
                    <Run Text="4. "/>
                    <Run Text="Im Cookie-Value-Feld: Strg+A → Strg+C → hier einfügen"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4" Text="dl_access Token (beginnt mit eyJ…):"
                   Foreground="{StaticResource FgMuted}"/>

        <TextBox x:Name="TokenBox" Grid.Row="6"
                 Height="70" AcceptsReturn="False" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"/>

        <TextBlock x:Name="ErrText" Grid.Row="8"
                   Foreground="#e74c3c" FontSize="11" Visibility="Collapsed"/>

        <StackPanel Grid.Row="12" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Abbrechen" Style="{StaticResource GrayBtn}"
                    Width="100" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Verbinden" Width="100" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
